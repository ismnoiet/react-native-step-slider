{
  "name": "react-native-step-slider",
  "version": "2.0.0",
  "description": "A smooth, customisable step slider for React Native with spring snap, animated progress fill and tap-to-select.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src/",
    "lib/"
  ],
  "keywords": [
    "react-native",
    "slider",
    "step",
    "stepper",
    "steps",
    "dot",
    "dots",
    "smooth",
    "interactive",
    "skia",
    "reanimated",
    "gesture-handler",
    "animation",
    "component"
  ],
  "author": "ismnoiet",
  "license": "MIT",
  "scripts": {
    "build": "bob build",
    "prepare": "bob build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismnoiet/react-native-step-slider.git"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      ["module", { "esm": true }],
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  }
}
